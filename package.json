{
  "name": "@omi-io/pkg-scripts",
  "version": "2.5.0",
  "description": "Build utilities and CLI for npm packages: esbuild pipelines, clean, and path aliases.",
  "author": "a-omi-io (https://github.com/a-omi-io)",
  "keywords": [
    "library-build",
    "monorepo",
    "nx",
    "nx-plugin",
    "release",
    "conventional-commits",
    "changelog",
    "pkg-scripts"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omi-io/pkg-scripts.git"
  },
  "homepage": "https://github.com/omi-io/pkg-scripts#readme",
  "bugs": {
    "url": "https://github.com/omi-io/pkg-scripts/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "omi-io-pkg": "bin/cli.mjs",
    "omi-io-pkg-release-with-config": "bin/release-with-config.cjs"
  },
  "main": "./src/index.mjs",
  "module": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./nx": "./src/nx-plugin.mjs",
    "./release-conventional-commits": "./src/release-conventional-commits.cjs",
    "./changelog-type-first-renderer": "./src/changelog-type-first-renderer.cjs",
    "./changelog-scope-filtered-renderer": "./src/changelog-scope-filtered-renderer.cjs"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "node scripts/run-tests.mjs",
    "prepublishOnly": "npm test",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "esbuild": "^0.20.2"
  },
  "peerDependencies": {
    "@nx/devkit": ">=19.0.0 <23.0.0",
    "nx": ">=19.0.0 <23.0.0"
  },
  "peerDependenciesMeta": {
    "@nx/devkit": {
      "optional": true
    },
    "nx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nx/devkit": "19.5.3",
    "glob": "^13.0.6",
    "nx": "19.5.3"
  }
}
